# API Keys — set via environment or edit this file
# These are loaded by scripts if present
BRAVE_API_KEY="${BRAVE_API_KEY:-}"
EXA_API_KEY="${EXA_API_KEY:-}"
TAVILY_API_KEY="${TAVILY_API_KEY:-}"
SERPER_API_KEY="${SERPER_API_KEY:-}"
FIRECRAWL_API_KEY="${FIRECRAWL_API_KEY:-}"

# Monthly budgets (USD) — scripts will refuse to run if exceeded
BRAVE_MONTHLY_BUDGET="${BRAVE_MONTHLY_BUDGET:-50}"
EXA_MONTHLY_BUDGET="${EXA_MONTHLY_BUDGET:-30}"
TAVILY_MONTHLY_BUDGET="${TAVILY_MONTHLY_BUDGET:-30}"
SERPER_MONTHLY_BUDGET="${SERPER_MONTHLY_BUDGET:-30}"
FIRECRAWL_MONTHLY_BUDGET="${FIRECRAWL_MONTHLY_BUDGET:-20}"
